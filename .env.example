GA4_PROPERTY_ID=410384180

# PostgreSQL (설정 시 JSON 대신 DB 사용)
# 로컬 Homebrew: postgresql://$(whoami)@localhost:5432/ga4_kpi
# Railway/Render: 플랫폼에서 자동 주입
DATABASE_URL=postgresql://USER@localhost:5432/ga4_kpi

# OAuth token JSON (Railway/Render — token.json 내용 한 줄)
# GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# 서비스 계정 키 파일 경로 (로컬)
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json

# 서비스 계정 JSON 전체 (Railway/Render 시크릿 — 파일 대신 사용)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# W1 리텐션 CSV (GA4 동질집단 탐색분석 내보내기)
COHORT_RETENTION_CSV=data/cohort_retention.csv

# MAU/신규 월별 보충 CSV (GA4 보고서 개요 내보내기)
GA4_OVERVIEW_CSV=data/ga4_overview.csv

# 신규 가입자 CSV (Firebase Console 내보내기)
USER_ACQUISITION_CSV=data/user_acquisition.csv
APP_DOWNLOADS_CSV=data/app_downloads.csv
