# Google Analytics 4 서비스 계정 키 (JSON 파일 경로 or 인라인 JSON)
GA4_PROPERTY_ID=410384180

# 서비스 계정 키 파일 경로 (apps/ga4-dashboard/ 기준)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# 또는 인라인 JSON (배포 환경용)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# 대시보드 인증 (선택)
DASHBOARD_PASSWORD=
